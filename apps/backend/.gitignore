# compiled output
/dist
# Isolated dist used by apps/desktop/scripts/package-backend.mjs so the
# packaging pipeline doesn't fight dev's nest start --watch (both would
# otherwise write to /dist, and nest-cli's deleteOutDir clobbers the
# dev backend mid-build → "Cannot find module './app.module'" crash).
/.dist-package
/node_modules
/build

# Logs
# Anchor to the package root so we don't accidentally ignore source dirs
# called `logs/` (we got bitten by this in apps/web — see commit d096eeb).
/logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS
.DS_Store

# Tests
/coverage
/.nyc_output

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json


# Environment (do not commit secrets)
.env
.env.local
.env.*.local

# temp directory
.temp
.tmp

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

/generated/prisma
