# ============================================================================
# Required — backend cannot start without these
# ============================================================================

# MySQL connection string used by Prisma. The DB itself is the source of
# truth for everything else (provider keys, history retention, storage
# settings, etc.) — see "Optional bootstrap" below.
DATABASE_URL=mysql://root:password@localhost:3306/canvas_flow

# HTTP port. The frontend (apps/web) defaults to http://localhost:18500.
PORT=18500

# Used to AES-256-GCM encrypt secrets stored in `global_configs`
# (DashScope API key, OpenAI API key, ...).
#   - Must be ≥ 32 chars.
#   - Generate with: openssl rand -base64 48
#   - DO NOT rotate after secrets are saved — rotation invalidates them.
ENCRYPTION_KEY=change-me-to-a-32-char-random-string


# ============================================================================
# Optional bootstrap — values below are migrated into the DB on first boot,
# then ignored. Edit them later from /admin/system in the browser.
# Leaving any of them blank is fine; the corresponding admin field will
# just say "未配置" until you fill it in.
# ============================================================================

# --- DashScope (Bailian) ----------------------------------------------------
# DB keys: dashscope.baseUrl, dashscope.apiKey (encrypted)
#
# IMPORTANT: this is the only model credential the OSS build strictly needs
# to be useful. Storage itself is local-disk only and needs no key.
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
DASHSCOPE_API_KEY=

# --- OpenAI-compatible (OpenAI / OpenRouter / vLLM / Together / Groq / ...) -
# DB keys: openai.baseUrl, openai.apiKey (encrypted)
#
# OPTIONAL. Leave blank if you only need DashScope models. When configured,
# unlocks model SKUs prefixed with `openai-chat/` (e.g. `openai-chat/gpt-4o-mini`,
# `openai-chat/anthropic/claude-3-haiku` for OpenRouter) and `openai-image/`
# (e.g. `openai-image/dall-e-3`). Add those SKUs to the relevant node's models
# list in /admin/config to expose them in the canvas UI.
#
# `OPENAI_BASE_URL` must include `/v1` and have no trailing slash:
#   - OpenAI:     https://api.openai.com/v1
#   - OpenRouter: https://openrouter.ai/api/v1
#   - vLLM:       http://your-host:8000/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# --- Local storage ----------------------------------------------------------
# DB keys: storage.local.{dataDir,maxFileSize}
#
# All uploads + mirrored model outputs land on the backend's local disk
# under STORAGE_LOCAL_DATA_DIR. They are served by the
# StaticUploadsController at `/static/uploads/<key>` (same origin as the
# API; no CORS to worry about).
#
# Defaults:
#   - STORAGE_LOCAL_DATA_DIR : /data/uploads (matches docker-compose volume)
#   - max file size         : 100 MiB
#
# For i2i / i2v workflows that need the model to fetch a reference image,
# the dashscope provider re-stages the local file to dashscope-temp at
# submit time — no extra config required here.
STORAGE_LOCAL_DATA_DIR=/data/uploads
