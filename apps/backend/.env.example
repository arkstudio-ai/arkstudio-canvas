# ============================================================================
# Required — backend cannot start without these
# ============================================================================

# MySQL connection string used by Prisma. The DB itself is the source of
# truth for everything else (provider keys, COS credentials, history
# retention, etc.) — see "Optional bootstrap" below.
DATABASE_URL=mysql://root:password@localhost:3306/canvas_flow

# HTTP port. The frontend (apps/web) defaults to http://localhost:18500.
PORT=18500

# Used to AES-256-GCM encrypt secrets stored in `global_configs`
# (DashScope API key, COS SecretId/SecretKey).
#   - Must be ≥ 32 chars.
#   - Generate with: openssl rand -base64 48
#   - DO NOT rotate after secrets are saved — rotation invalidates them.
ENCRYPTION_KEY=change-me-to-a-32-char-random-string


# ============================================================================
# Optional bootstrap — values below are migrated into the DB on first boot,
# then ignored. Edit them later from /admin/system in the browser.
# Leaving any of them blank is fine; the corresponding admin field will
# just say "未配置" until you fill it in.
# ============================================================================

# --- DashScope (Bailian) ----------------------------------------------------
# DB keys: dashscope.baseUrl, dashscope.apiKey (encrypted)
#
# IMPORTANT: this is the only "model + storage" credential the OSS build
# strictly needs to be useful. Without it (and without COS) the upload
# endpoint returns 400 because there's nowhere to put the bytes.
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
DASHSCOPE_API_KEY=

# --- Object Storage (Tencent COS) -------------------------------------------
# DB keys: storage.cos.{secretId,secretKey,bucket,region,customDomain,signExpires,maxFileSize}
#
# COS is OPTIONAL. The runtime auto-falls-back when these are blank:
#   - COS configured       → uploads go to your bucket; long-lived URLs
#   - DashScope key only   → uploads go to DashScope's free temporary
#                            store as `oss://...` URLs (48h TTL, 100MB
#                            cap, Beijing region only)
#   - neither              → upload endpoint returns 400
#
# /admin/system shows the currently effective strategy at the top of
# the storage card so operators don't have to guess.
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-hongkong
COS_CUSTOM_DOMAIN=
COS_SIGN_EXPIRES=3600
# Bytes. 100 MiB default. (DashScope temp fallback hard-caps at the same
# 100 MiB regardless of this knob.)
COS_MAX_FILE_SIZE=104857600
