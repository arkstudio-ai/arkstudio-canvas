# ============================================================================
# docker-compose 环境变量模板。
#
# 用法：
#   cp .env.docker.example .env
#   # 至少改一项 ENCRYPTION_KEY，然后：
#   docker compose up -d --build
#
# compose 里凡是 ${VAR:-default} 的字段，env 留空就走 default。
# 凡是 ${VAR:?msg} 的字段必填（缺了 compose 会拒绝启动）。
# ============================================================================

# ----- Required（必填，不填启动失败）---------------------------------------

# AES-256-GCM 加密 DashScope / OpenAI 凭据用；≥ 32 字符。
# 生成：openssl rand -base64 48
# ⚠️ 不要在生产环境用这个示例值！第一次启动后也不要轮换 —— 旧密文会解不开。
ENCRYPTION_KEY=DEMO_DO_NOT_USE_IN_PRODUCTION_change_me_to_32_plus_chars_random


# ----- Optional：MySQL 默认就够，想自定义可改 ------------------------------

# MySQL root 密码 + 库名
# MYSQL_ROOT_PASSWORD=canvas_flow_root
# MYSQL_DATABASE=canvas_flow

# Web 对外端口（默认 8080，避免和本地 dev 5173 冲突）
# WEB_PORT=8080


# ----- Optional bootstrap：填了第一次启动会迁到 DB，之后从 /admin/system 改 -

# 阿里云百炼 API Key —— 不填的话第一次启动后到 /admin/system 填也行
#
# ⚠️ 想"开箱即用"跑通完整链路（含图片/视频生成 + i2i/i2v 上传中转），至少要在
#   这里或 /admin/system 填一份 DASHSCOPE_API_KEY。
# DASHSCOPE_API_KEY=sk-...
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com

# OpenAI-compatible（OpenAI / OpenRouter / 自建 vLLM / Together / Groq）
# 可选；配了之后能用 openai-chat/<model>、openai-image/<model> 这两个 SKU。
# baseUrl 要带 /v1 且末尾不要斜线。
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1


# ----- Optional：本地存储 ---------------------------------------------------

# 上传 + 模型生成结果落盘的根目录。
# - docker compose 默认值是 /data/uploads，已挂到 named volume canvas_flow_uploads，
#   `docker compose down` 不丢数据；
# - 想换路径（例如挂宿主机目录方便备份）就改这里，并同步改 docker-compose.yml
#   里 backend service 的 volume 映射。
# - 同名设置在 /admin/system → 本地存储 也能改，DB 优先级更高（admin > env > 默认）。
# STORAGE_LOCAL_DATA_DIR=/data/uploads
