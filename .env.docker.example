# ============================================================================
# docker-compose 环境变量模板。
#
# 用法：
#   cp .env.docker.example .env
#   # 至少改一项 ENCRYPTION_KEY，然后：
#   docker compose up -d --build
#
# compose 里凡是 ${VAR:-default} 的字段，env 留空就走 default。
# 凡是 ${VAR:?msg} 的字段必填（缺了 compose 会拒绝启动）。
# ============================================================================

# ----- Required（必填，不填启动失败）---------------------------------------

# AES-256-GCM 加密 DashScope/COS 凭据用；≥ 32 字符。
# 生成：openssl rand -base64 48
# ⚠️ 不要在生产环境用这个示例值！第一次启动后也不要轮换 —— 旧密文会解不开。
ENCRYPTION_KEY=DEMO_DO_NOT_USE_IN_PRODUCTION_change_me_to_32_plus_chars_random


# ----- Optional：MySQL 默认就够，想自定义可改 ------------------------------

# MySQL root 密码 + 库名
# MYSQL_ROOT_PASSWORD=canvas_flow_root
# MYSQL_DATABASE=canvas_flow

# Web 对外端口（默认 8080，避免和本地 dev 5173 冲突）
# WEB_PORT=8080


# ----- Optional bootstrap：填了第一次启动会迁到 DB，之后从 /admin/system 改 -

# 阿里云百炼 API Key —— 不填的话第一次启动后到 /admin/system 填也行
# DASHSCOPE_API_KEY=sk-...
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com

# 腾讯云 COS 凭据 —— 不填则上传/转存功能未启用，模型生成的资源保留原始上游 URL
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_BUCKET=
# COS_REGION=ap-hongkong
# COS_CUSTOM_DOMAIN=
